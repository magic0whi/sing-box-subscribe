{
  "log": {
    "level": "info",
    "timestamp": true,
    "output": "/tmp/sing-box.log"
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9091",
      "external_ui": "ui",
      "secret": "",
      "external_ui_download_url": "https://mirror.ghproxy.com/https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip",
      "external_ui_download_detour": "direct",
      "default_mode": "rule"
    },
    "cache_file": {
      "enabled": true,
      "store_fakeip": false
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "dhcpDNS",
        "address": "dhcp://auto",
        "detour": "direct"
      },
      {
        "tag": "proxyDNS",
        "address": "tls://8.8.8.8",
        "detour": "proxy"
      },
      {
        "tag": "localDNS",
        "address": "tls://223.5.5.5",
        "detour": "direct"
      },
      {
        "tag": "block",
        "address": "rcode://success"
      }
    ],
    "rules": [
      {
        "domain": [
          "ghproxy.com",
          "cdn.jsdelivr.net",
          "testingcf.jsdelivr.net",
          "captive.apple.com",
          "detectportal.firefox.com",
          "w0f.cn",
          "securelogin.arubanetworks.com"
        ],
        "domain_suffix": [
          ".exands.com"
        ],
        "outbound": "any",
        "disable_cache": true,
        "server": "dhcpDNS"
      },
      {
        "rule_set": "geosite-cn",
        "server": "localDNS"
      },
      {
        "clash_mode": "direct",
        "server": "localDNS"
      },
      {
        "clash_mode": "global",
        "server": "proxyDNS"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "server": "proxyDNS"
      },
      {
        "rule_set": "geosite-category-ads-all",
        "server": "block"
      }
    ],
    "final": "localDNS",
    "strategy": "prefer_ipv6"
  },
  "inbounds": [
    {
      "type": "tun",
      "inet4_address": "172.19.0.1/30",
      "inet6_address": "fdfe:dcba:9876::1/126",
      "mtu": 9000,
      "gso": true,
      "auto_route": true,
      "strict_route": false,
      "sniff": true,
      "endpoint_independent_nat": false,
      "stack": "system",
      "exclude_interface": [
        "docker",
        "optun",
        "yggdrasil"
      ],
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 2080
        }
      }
    },
    {
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 2080,
      "sniff": true,
      "users": []
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "type": "selector",
      "outbounds": [
        "auto",
        "direct",
        "{all}"
      ]
    },
    {
      "tag": "OpenAI",
      "type": "selector",
      "outbounds": [
        "TaiWan",
        "Singapore",
        "Japan",
        "America",
        "Others"
      ],
      "default": "America"
    },
    {
      "tag": "Google",
